---
import "./../styles/global.css"

import Header from"./../components/Header.astro"
import Footer from "./../components/Footer.astro"
import Layout from "../layouts/Layout.astro";

import {frontmatter, Content} from "../data/vithusan.md"
---

<Layout>
    <div class="dark:bg-gray-900 bg-blue-200 w-full h-max py-20 min-h-screen">
        <div class="prose dark:prose-invert mx-auto w-full max-w-none md:max-w-4xl">
            <Header />
                <div class="py-12">
                    <Content/>
                </div>
            <Footer />
        </div>
    </div>
</Layout>