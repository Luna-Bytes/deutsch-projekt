---
import Layout from '../layouts/Layout.astro';
import "../styles/global.css"

import { Content, frontmatter} from "../data/index.md";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout>
	<div class="dark:bg-gray-900 bg-blue-200 w-full h-max py-20 px-4">
		<div class="prose dark:prose-invert mx-auto w-full max-w-none md:max-w-4xl text-wrap wrap-break-word">
			<Header/>
			<div class="py-12">
				<Content/>
			</div>
			<Footer/>
		</div>
	</div>
</Layout>
