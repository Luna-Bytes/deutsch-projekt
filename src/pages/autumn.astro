---
import "./../styles/global.css"

import Header from"./../components/Header.astro"
import Footer from "./../components/Footer.astro"
import Layout from "../layouts/Layout.astro";
import GeniusText from "../assets/GeniusText";

import type {Segment} from "../assets/GeniusText";

const segments: Segment[] = [
    { type: "text", content: "LOHENGRIN" },
    { type: "break" },
    { type: "text", content: "Elsa, soll ich dein Gatte heißen," },
    { type: "break" },
    { type: "text", content: "soll Land und Leut' ich schirmen dir," },
    { type: "break" },
    { type: "text", content: "soll nichts mich wieder von dir reißen," },
    { type: "break" },
    {
        type: "note",
        id: "n1-bedingung",
        content: "mußt eines du geloben mir:",
        label: "Der Vertrag",
        note: "Die Ehe wird hier explizit als Bedingung formuliert, nicht als bedingungslose Liebe. Lohengrin liebt Elsa offenbar wirklich, verlangt aber zuerst ein Versprechen – die Beziehung steht von Anfang an unter einem Vorbehalt. Das nimmt die spätere Katastrophe vorweg: Vertrauen wird hier nicht gewachsen, sondern eingefordert.",
    },
    { type: "break" },
    {
        type: "note",
        id: "n2-frageverbot",
        content: "Nie sollst du mich befragen,\nnoch Wissens Sorge tragen,\nwoher ich kam der Fahrt,\nnoch wie mein Nam' und Art!",
        label: "Das Frageverbot",
        note: "Das zentrale Motiv der Oper: das klassische Melusinen- bzw. 'Cupid & Psyche'-Motiv des verbotenen Wissens. Identität wird hier zur Ware, die gegen Vertrauen getauscht wird – wer fragt, verliert. Wagner nutzt das Verbot als dramaturgische Zeitbombe: Der gesamte dritte Akt existiert nur, damit diese Zeile gebrochen wird.",
    },
    { type: "break" },
    { type: "text", content: "ELSA" },
    { type: "text", content: " (fast bewußtlos)" },
    { type: "break" },
    {
        type: "note",
        id: "n3-schwur",
        content: "Nie, Herr, soll mir die Frage kommen!",
        label: "Der Schwur",
        note: "Dramatische Ironie in Reinform: Elsa schwört genau das, was sie im dritten Akt nicht einhalten wird. Ihr 'fast bewußtlos' in der Regieanweisung deutet an, dass sie in diesem Moment gar nicht wirklich frei entscheidet – sie ist von Lohengrins Erscheinung überwältigt, nicht überzeugt.",
    },
    { type: "break" },
    { type: "text", content: "LOHENGRIN" },
    { type: "break" },
    { type: "text", content: "Elsa! Hast du mich wohl vernommen?" },
    { type: "break" },
    {
        type: "note",
        id: "n2-frageverbot",
        content: "Nie sollst du mich befragen,\nnoch Wissens Sorge tragen,\nwoher ich kam der Fahrt,\nnoch wie mein Nam' und Art!",
        label: "Das Frageverbot",
        note: "Die Wiederholung ist selbst schon Regieanweisung: Lohengrin traut dem ersten Schwur nicht und lässt sich das Verbot noch einmal bestätigen. Musikalisch wie textlich insistiert die Szene auf einem Verbot, das kaum ausgesprochen ist, wenn man schon ahnt, dass es fallen wird.",
    },
    { type: "break" },
    { type: "text", content: "ELSA" },
    { type: "text", content: " (mit großer Innigkeit zu ihm aufblickend)" },
    { type: "break" },
    {
        type: "note",
        id: "n4-vergoettlichung",
        content: "Mein Schirm! Mein Engel! Mein Erlöser,",
        label: "Vergöttlichung",
        note: "Elsa spricht Lohengrin in einer Sprache an, die eigentlich religiöser Anbetung vorbehalten ist ('Engel', 'Erlöser'). Sie liebt nicht einen Menschen, sondern eine Erlösergestalt – das macht sie besonders anfällig für Ortruds spätere Zweifel-Rhetorik, denn ein Gott, der sich nicht erklärt, wirkt schnell wie ein Trugbild.",
    },
    { type: "break" },
    { type: "text", content: "der fest an meine Unschuld glaubt!" },
    { type: "break" },
    {
        type: "note",
        id: "n5-zweifelsparadox",
        content: "Wie gäb' es Zweifels Schuld, die größer,\nals die an dich den Glauben raubt?",
        label: "Das Zweifelsparadox",
        note: "Elsa formuliert hier unbewusst die Logik, mit der Ortrud sie später manipulieren wird: Zweifel wird selbst zur Schuld erklärt. Damit macht sich Elsa das Fragen von vornherein moralisch unmöglich – nicht Lohengrin verbietet es zuletzt, sie hat es sich selbst schon verboten.",
    },
    { type: "break" },
    { type: "text", content: "Wie du mich schirmst in meiner Not," },
    { type: "break" },
    { type: "text", content: "so halt' in Treu' ich dein Gebot!" },
    { type: "break" },
    { type: "text", content: "LOHENGRIN" },
    { type: "break" },
    {
        type: "note",
        id: "n6-liebeserklaerung",
        content: "Elsa, ich liebe dich!",
        label: "Der Bruch im Ritual",
        note: "Nach zwei Strophen formelhaften Schwörens der einzige schlichte, unbedingte Satz der ganzen Szene – ohne Bedingung, ohne Gebot. Genau dieser Kontrast zeigt, wie sehr das Frageverbot eine echte Zuneigung überlagert, die eigentlich keine Bedingungen bräuchte.",
    },
];


---

<Layout>
    <div class="dark:bg-gray-900 bg-blue-200 w-full h-max py-20 min-h-screen">
        <div class="prose dark:prose-invert mx-auto w-full max-w-none md:max-w-4xl">
            <Header />
            <GeniusText
                    client:load
                    title="Lohengrin"
                    subtitle="Erklärung von Autumn"
                    segments={segments}
            />
            <Footer />
        </div>
    </div>
</Layout>